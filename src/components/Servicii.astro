---
import { SERVICES } from "../config";

// Lucide-style icons inline. Stroke neutral, accent applied per-tile.
// 01 blat bucătărie cu chiuvetă · 02 butcher block (end-grain) · 03 masă · 04 glafuri/polițe
const ICONS: Record<string, string> = {
  "01": `<rect x="3" y="8" width="18" height="4" rx="1" /><path d="M5 12v8M19 12v8" /><circle cx="12" cy="10" r="1.1" />`,
  "02": `<rect x="4" y="4" width="16" height="16" rx="1.5" /><path d="M4 9.3h16M4 14.6h16M9.3 4v16M14.6 4v16" />`,
  "03": `<path d="M3 8h18l-1.5 2.5H4.5L3 8Z" /><path d="M6 10.5V20M18 10.5V20" />`,
  "04": `<rect x="3" y="6" width="18" height="3.5" rx="1" /><rect x="3" y="14.5" width="18" height="3.5" rx="1" />`,
};
---

<section id="servicii" class="section-pad border-t border-[var(--color-rule)] bg-[var(--color-paper)]">
  <div class="container-base">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-end mb-12 lg:mb-16">
      <div class="lg:col-span-6 reveal-heading">
        <div class="text-eyebrow mb-3">04 &mdash; Ce facem</div>
        <h2 class="text-display-l">
          Patru categorii. <span class="italic text-[var(--color-forest)]">Un singur standard.</span>
        </h2>
      </div>
      <div class="lg:col-span-5 lg:col-start-8 max-w-[58ch] reveal" style="transition-delay: 150ms;">
        <p class="text-lg text-[var(--color-ink-2)] leading-relaxed">
          Nu facem mobilă întreagă și nu vindem pal. Facem un singur lucru —
          blaturi din lemn masiv — și îl facem bine.
          <span class="text-[var(--color-ink)]">Restul, recomandăm pe altcineva.</span>
        </p>
      </div>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 border-t border-l border-[var(--color-rule)]">
      {SERVICES.map((s, i) => (
        <li
          class="border-r border-b border-[var(--color-rule)] reveal-scale group relative"
          style={`transition-delay: ${i * 100}ms`}
        >
          <a
            href="#contact"
            class="block p-7 md:p-9 lg:p-10 h-full hover:bg-[var(--color-forest-soft)] transition-colors duration-300"
          >
            <div class="flex items-center justify-between mb-6">
              <div class="font-mono-tabular text-xs text-[var(--color-gold-hi)] tracking-[0.16em]">
                {s.n}
              </div>
              <span
                class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-[var(--color-forest-soft)] text-[var(--color-forest)] group-hover:bg-[var(--color-gold)] group-hover:text-[var(--color-forest-deep)] transition-all duration-300"
                aria-hidden="true"
              >
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={ICONS[s.n]}
                />
              </span>
            </div>
            <h3 class="text-display-m mb-3 group-hover:text-[var(--color-forest)] transition-colors">
              {s.title}
            </h3>
            <p class="text-[var(--color-ink-2)] leading-relaxed max-w-[42ch]">
              {s.body}
            </p>
            <div class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-forest)] group-hover:text-[var(--color-gold-hi)] transition-colors">
              <span>Cere ofertă</span>
              <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
