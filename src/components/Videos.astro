---
import { VIDEOS } from "../config";
---

<section id="video" class="relative section-pad bg-[var(--color-forest-deep)] text-[var(--color-paper)] overflow-hidden">
  <!-- Subtle gold radial atmosphere -->
  <div
    class="pointer-events-none absolute inset-0 -z-0"
    aria-hidden="true"
    style="background: radial-gradient(ellipse at 30% 25%, oklch(78% 0.13 80 / 0.12) 0%, transparent 60%);"
  ></div>

  <div class="container-base relative z-10">
    <div class="grid lg:grid-cols-12 gap-10 items-end mb-12 lg:mb-16">
      <div class="lg:col-span-7 reveal-heading">
        <div class="font-mono-tabular text-xs uppercase tracking-[0.18em] text-[var(--color-gold)] mb-3">
          03 &mdash; Video
        </div>
        <h2 class="text-display-l text-[var(--color-paper)]">
          Vezi cum <span class="italic text-[var(--color-gold)]">tăiem</span> un buștean în blaturi.
        </h2>
      </div>
      <div class="lg:col-span-4 lg:col-start-9 text-[var(--color-paper)]/75 leading-relaxed reveal" style="transition-delay: 150ms;">
        Filmări adevărate, de la noi. Așa transformăm un copac întreg în blaturi groase — fără trucuri, exact cum se face.
      </div>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {VIDEOS.map((v, i) => (
        <li class="reveal-scale" style={`transition-delay: ${i * 120}ms`}>
          <figure class="video-card group relative bg-[var(--color-forest)] border border-[var(--color-paper)]/10 overflow-hidden">
            <div class="relative aspect-[9/16]">
              <video
                class="absolute inset-0 w-full h-full object-cover bg-[var(--color-forest-deep)]"
                src={v.src}
                poster={v.poster}
                preload="metadata"
                playsinline
                muted
                loop
                controls
                aria-label={`${v.title} — ${v.body}`}
                data-video
              ></video>
              <!-- Bottom gradient for caption legibility (over poster) -->
              <div
                class="video-gradient pointer-events-none absolute inset-x-0 bottom-0 h-2/5"
                style="background: linear-gradient(180deg, transparent 0%, oklch(22% 0.045 150 / 0.85) 100%);"
                aria-hidden="true"
              ></div>
              <!-- Sound overlay — tap to unmute once autoplay has started -->
              <button
                type="button"
                class="video-play absolute inset-0 w-full h-full flex items-center justify-center text-[var(--color-paper)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-gold)]"
                aria-label={`Pornește sunetul: ${v.title}`}
                data-play
              >
                <!-- Sound-off icon (shown while muted/paused) -->
                <span class="video-icon-sound w-14 h-14 rounded-full bg-[var(--color-gold)]/80 text-[var(--color-forest-deep)] flex items-center justify-center transition-transform duration-300 group-hover:scale-110 backdrop-blur-sm" aria-hidden="true">
                  <svg width="22" height="20" viewBox="0 0 22 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="1,5 1,15 6,15 13,20 13,0 6,5" fill="currentColor" stroke="none"/>
                    <line x1="17" y1="7" x2="21" y2="13"/><line x1="21" y1="7" x2="17" y2="13"/>
                  </svg>
                </span>
              </button>
              <!-- Caption (poster state) -->
              <figcaption class="video-cap absolute bottom-4 left-4 right-4 z-10 pointer-events-none">
                <div class="font-display text-lg md:text-xl text-[var(--color-paper)]">
                  {v.title}
                </div>
                <div class="font-mono-tabular text-[11px] uppercase tracking-[0.14em] text-[var(--color-paper)]/75 mt-1">
                  №{String(i + 1).padStart(2, "0")} &middot; {v.body}
                </div>
              </figcaption>
            </div>
          </figure>
        </li>
      ))}
    </ul>

    <p class="mt-8 text-sm font-mono-tabular uppercase tracking-[0.14em] text-[var(--color-paper)]/55">
      Atinge un video ca să pornești sunetul
    </p>
  </div>
</section>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  type Ref = { card: Element; video: HTMLVideoElement; btn: HTMLElement; unmuted: boolean };
  const refs: Ref[] = [];

  document.querySelectorAll<HTMLElement>("[data-play]").forEach((btn) => {
    const card = btn.closest(".video-card");
    if (!card) return;
    const video = card.querySelector<HTMLVideoElement>("[data-video]");
    if (!video) return;
    refs.push({ card, video, btn, unmuted: false });
  });

  const enterPlaying = (ref: Ref) => {
    ref.card.classList.add("is-playing");
  };
  const exitPlaying = (ref: Ref) => {
    ref.card.classList.remove("is-playing");
  };

  // Tap: first tap unmutes, second tap pauses/plays
  refs.forEach((ref) => {
    ref.btn.addEventListener("click", () => {
      if (!ref.video.paused && ref.video.muted) {
        // Mute all others first
        refs.forEach((other) => {
          if (other !== ref) { other.video.muted = true; other.unmuted = false; }
        });
        ref.video.muted = false;
        ref.unmuted = true;
        return;
      }
      if (ref.video.paused) {
        refs.forEach((other) => {
          if (other !== ref) { other.video.muted = true; other.unmuted = false; }
        });
        ref.video.muted = false;
        ref.unmuted = true;
        ref.video.play().catch(() => {});
      } else {
        ref.video.pause();
        ref.video.muted = true;
        ref.unmuted = false;
        exitPlaying(ref);
      }
    });
    ref.video.addEventListener("play",  () => enterPlaying(ref));
    ref.video.addEventListener("pause", () => { if (!ref.unmuted) exitPlaying(ref); });
  });

  // Autoplay on scroll — muted, loop, starts when 50% in viewport, pauses when out
  if (!reduceMotion && "IntersectionObserver" in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const ref = refs.find((r) => r.video === entry.target);
        if (!ref) return;
        if (entry.isIntersecting) {
          ref.video.muted = true;
          ref.video.loop = true;
          ref.video.play().catch(() => {});
        } else {
          if (!ref.unmuted) {
            ref.video.pause();
            ref.video.currentTime = 0;
            exitPlaying(ref);
          }
        }
      });
    }, { threshold: 0.5 });
    refs.forEach((r) => io.observe(r.video));
  }
</script>

<style>
  /* Hide caption and gradient once video starts playing */
  .video-card.is-playing .video-gradient,
  .video-card.is-playing .video-cap {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 350ms var(--ease-out-quart);
  }
  /* Sound icon fades to subtle when video is playing muted */
  .video-card.is-playing .video-icon-sound {
    opacity: 0.55;
    transform: scale(0.85);
    transition: opacity 350ms var(--ease-out-quart), transform 350ms var(--ease-out-quart);
  }
  .video-card.is-playing .video-play:hover .video-icon-sound {
    opacity: 0.9;
    transform: scale(0.95);
  }
</style>
