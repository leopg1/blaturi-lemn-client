---
import { COVERAGE_LOCATIONS } from "../config";
const track = [...COVERAGE_LOCATIONS, ...COVERAGE_LOCATIONS];
---

<section id="acoperire" class="py-20 md:py-28 border-t border-[var(--color-rule)] overflow-hidden bg-[var(--color-paper)]">
  <div class="container-base mb-10 md:mb-14">
    <div class="grid lg:grid-cols-12 gap-10 items-end">
      <div class="lg:col-span-7 reveal-heading">
        <div class="text-eyebrow mb-3">08 &mdash; Unde livrăm</div>
        <h2 class="text-display-l">
          Din <span class="italic text-[var(--color-forest)]">Bucovina</span>,
          în toată <span class="italic text-[var(--color-forest)]">România</span>.
        </h2>
      </div>
      <div class="lg:col-span-4 lg:col-start-9 text-[var(--color-ink-2)] leading-relaxed reveal" style="transition-delay: 150ms;">
        Lucrăm blatul la noi în atelier și îl livrăm oriunde — prin curier de marfă, ambalat cu grijă. Sună-ne, restul rezolvăm noi.
      </div>
    </div>
  </div>

  <div class="marquee" aria-label="Orașe în care livrăm">
    <div class="marquee-track font-display font-medium text-[var(--color-forest)]" style="font-size: clamp(2rem, 5vw, 4.5rem); line-height: 1.1;">
      {track.map((loc) => (
        <span class="inline-flex items-center gap-12">
          <span>{loc}</span>
          <span class="text-[var(--color-gold)]" aria-hidden="true">●</span>
        </span>
      ))}
    </div>
  </div>
</section>
