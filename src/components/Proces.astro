---
import { PROCES } from "../config";
---

<section id="proces" class="section-pad bg-[var(--color-paper-2)] border-t border-[var(--color-rule)]">
  <div class="container-base">
    <div class="grid lg:grid-cols-12 gap-10 mb-14 lg:mb-20">
      <div class="lg:col-span-8 reveal-heading">
        <div class="text-eyebrow mb-3">06 &mdash; Cum lucrăm</div>
        <h2 class="text-display-l">
          Cinci pași de la <span class="italic text-[var(--color-forest)]">primul mesaj</span> la <span class="italic text-[var(--color-forest)]">blatul montat</span>.
        </h2>
      </div>
    </div>

    <ol class="relative">
      {PROCES.map((p, i) => {
        const isOdd = i % 2 === 1;
        return (
          <li
            class={`grid lg:grid-cols-12 gap-6 lg:gap-12 items-baseline py-10 md:py-12 lg:py-14 border-t border-[var(--color-rule)] reveal ${i === PROCES.length - 1 ? "border-b" : ""}`}
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class={`lg:col-span-2 ${isOdd ? "lg:order-3 lg:text-right" : ""}`}>
              <span
                class="font-display text-[var(--color-gold-hi)] leading-none block"
                style="font-size: clamp(2.75rem, 4.5vw, 4.75rem);"
              >
                {p.n}
              </span>
            </div>
            <div class={`lg:col-span-10 ${isOdd ? "lg:order-1 lg:pr-12" : "lg:pl-2"}`}>
              <h3 class="text-display-m mb-3 max-w-[18ch]">{p.t}</h3>
              <p class="text-[var(--color-ink-2)] text-lg leading-relaxed max-w-[58ch]">
                {p.b}
              </p>
            </div>
          </li>
        );
      })}
    </ol>
  </div>
</section>
