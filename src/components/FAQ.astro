---
import { FAQ } from "../config";
---

<section id="faq" class="section-pad border-t border-[var(--color-rule)] bg-[var(--color-paper)]">
  <div class="container-base">
    <div class="grid lg:grid-cols-12 gap-10 mb-12 lg:mb-16">
      <div class="lg:col-span-5 reveal-heading">
        <div class="text-eyebrow mb-3">08 &mdash; Ce ne întreabă lumea</div>
        <h2 class="text-display-l">
          <span class="italic text-[var(--color-forest)]">Răspunsuri</span> directe.
        </h2>
      </div>
      <div class="lg:col-span-6 lg:col-start-7 text-[var(--color-ink-2)] text-lg leading-relaxed max-w-[52ch] reveal" style="transition-delay: 150ms;">
        Întrebările pe care le primim cel mai des, cu răspunsurile pe care le dau la telefon. Dacă nu găsești ce-ți trebuie, sună — vorbim cinci minute.
      </div>
    </div>

    <ul class="border-t border-[var(--color-rule)]">
      {FAQ.map((item, i) => (
        <li class="border-b border-[var(--color-rule)] reveal" style={`transition-delay: ${i * 60}ms`}>
          <details class="group" open={i === 0} name="faq">
            <summary class="flex items-start justify-between gap-6 py-6 md:py-8 cursor-pointer list-none">
              <div class="flex items-baseline gap-5 md:gap-7">
                <span class="font-mono-tabular text-xs md:text-sm text-[var(--color-gold-hi)] tracking-[0.14em] pt-1">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <h3 class="font-display text-xl md:text-2xl lg:text-[28px] leading-tight text-[var(--color-ink)] group-hover:text-[var(--color-forest)] transition-colors">
                  {item.q}
                </h3>
              </div>
              <span
                class="flex-shrink-0 w-9 h-9 rounded-full border border-[var(--color-rule)] flex items-center justify-center text-[var(--color-ink-2)] group-hover:border-[var(--color-gold)] group-hover:bg-[var(--color-gold)] group-hover:text-[var(--color-forest-deep)] transition-colors mt-1"
                aria-hidden="true"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 14 14"
                  fill="none"
                  class="transition-transform duration-300 group-open:rotate-45"
                >
                  <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" />
                  <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" />
                </svg>
              </span>
            </summary>
            <div class="pb-7 md:pb-9 pl-11 md:pl-14 pr-12 max-w-[64ch]">
              <p class="text-[var(--color-ink-2)] text-base md:text-lg leading-relaxed">
                {item.a}
              </p>
            </div>
          </details>
        </li>
      ))}
    </ul>
  </div>
</section>
