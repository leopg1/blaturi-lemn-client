---
import { SITE } from "../config";

const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-forest-deep)] text-[var(--color-paper)]/65 border-t border-[var(--color-paper)]/15">
  <div class="container-base py-10 md:py-14">
    <div class="flex flex-col items-center text-center gap-6">
      <a href="#sus" class="footer-logo-link inline-block">
        <img
          src={SITE.logo}
          alt={`${SITE.brand} — ${SITE.tagline}`}
          class="footer-logo block h-14 md:h-16 w-auto"
          width="360"
          height="88"
          loading="lazy"
          decoding="async"
        />
      </a>

      <div class="font-mono-tabular text-xs uppercase tracking-[0.16em] text-[var(--color-paper)]/55 flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
        <span>Atelier {SITE.city}, jud. {SITE.county}</span>
        <span class="text-[var(--color-gold)]/60" aria-hidden="true">·</span>
        <span>Livrăm în toată România</span>
        <span class="text-[var(--color-gold)]/60" aria-hidden="true">·</span>
        <span>Lemn masiv, atelier propriu</span>
        <span class="text-[var(--color-gold)]/60" aria-hidden="true">·</span>
        <span>© {year} {SITE.brand}</span>
      </div>
    </div>
  </div>

  <style>
    /* Convert green logo to cream over forest-deep background */
    .footer-logo {
      filter: brightness(0) invert(1);
      transition: opacity 300ms var(--ease-out-quart), transform 300ms var(--ease-out-quart);
      opacity: 0.95;
    }
    .footer-logo-link:hover .footer-logo {
      opacity: 1;
      transform: scale(1.02);
    }
  </style>
</footer>
