---
import { DOVEZI } from "../config";
---

<section id="de-ce-noi" class="section-pad border-t border-[var(--color-rule)] bg-[var(--color-paper)]">
  <div class="container-base">
    <div class="grid lg:grid-cols-12 gap-10 mb-12 lg:mb-16">
      <div class="lg:col-span-6 reveal-heading">
        <div class="text-eyebrow mb-3">05 &mdash; De ce noi</div>
        <h2 class="text-display-l">
          Patru lucruri pe care<br />
          <span class="italic text-[var(--color-forest)]">le poți verifica.</span>
        </h2>
      </div>
      <div class="lg:col-span-5 lg:col-start-8 reveal" style="transition-delay: 150ms;">
        <p class="text-lg text-[var(--color-ink-2)] leading-relaxed">
          Tăiem și lucrăm lemn de 15 ani. Doar lemn masiv, nu pal. Vii, vezi blatul pe viu
          și plătești cât scrie pe ofertă. Astea-s lucrurile care contează — nu vorbele.
        </p>
      </div>
    </div>

    <ul class="grid grid-cols-2 lg:grid-cols-4 border-t border-l border-[var(--color-rule)]">
      {DOVEZI.map((d, i) => (
        <li
          class="border-r border-b border-[var(--color-rule)] p-6 md:p-8 lg:p-10 reveal-scale group relative bg-[var(--color-paper)] hover:bg-[var(--color-forest-soft)] transition-colors duration-300"
          style={`transition-delay: ${i * 100}ms`}
        >
          <!-- Top hairline accent -->
          <span class="absolute top-0 left-0 h-[2px] w-10 bg-[var(--color-gold)] group-hover:w-full transition-all duration-500 [transition-timing-function:var(--ease-out-expo)]" aria-hidden="true"></span>

          <div class="flex items-baseline gap-2 mb-3">
            <span
              class="font-display font-medium text-[var(--color-forest)] leading-none"
              style="font-size: clamp(3rem, 6vw, 5.25rem);"
            >
              {d.num}
            </span>
            {d.unit && (
              <span class="font-mono-tabular text-sm text-[var(--color-ink-3)] uppercase tracking-[0.14em]">
                {d.unit}
              </span>
            )}
          </div>
          <div class="text-sm md:text-base text-[var(--color-ink-2)] leading-snug max-w-[24ch]">
            {d.label}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
