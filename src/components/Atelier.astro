---
import { ATELIER } from "../config";
---

<section id="atelier" class="relative section-pad bg-[var(--color-forest-deep)] text-[var(--color-paper)] overflow-hidden border-t border-[var(--color-paper)]/10">
  <!-- Subtle gold radial atmosphere -->
  <div
    class="pointer-events-none absolute inset-0 -z-0"
    aria-hidden="true"
    style="background: radial-gradient(ellipse at 70% 30%, oklch(78% 0.13 80 / 0.12) 0%, transparent 60%);"
  ></div>

  <div class="container-base relative z-10">
    <div class="grid lg:grid-cols-12 gap-10 items-end mb-12 lg:mb-16">
      <div class="lg:col-span-7 reveal-heading">
        <div class="font-mono-tabular text-xs uppercase tracking-[0.18em] text-[var(--color-gold)] mb-3">
          04 &mdash; Din pădure în atelier
        </div>
        <h2 class="text-display-l text-[var(--color-paper)]">
          Pornim de la <span class="italic text-[var(--color-gold)]">bușteanul întreg</span>.
        </h2>
      </div>
      <div class="lg:col-span-4 lg:col-start-9 text-[var(--color-paper)]/75 leading-relaxed reveal" style="transition-delay: 150ms;">
        Alegem bușteni buni și îi tăiem noi în blaturi groase. De aici începe fiecare masă și fiecare blat — așa știi exact de unde vine lemnul tău.
      </div>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-8 max-w-4xl">
      {ATELIER.map((a, i) => (
        <li class="reveal-scale" style={`transition-delay: ${i * 120}ms`}>
          <figure class="group relative bg-[var(--color-forest)] border border-[var(--color-paper)]/10 overflow-hidden img-zoom">
            <div class="relative aspect-[4/5]">
              <img
                class="absolute inset-0 w-full h-full object-cover bg-[var(--color-forest-deep)]"
                src={a.image}
                alt={`${a.title} — ${a.body}`}
                loading="lazy"
                decoding="async"
              />
              <!-- Subtle bottom gradient for caption legibility -->
              <div
                class="pointer-events-none absolute inset-x-0 bottom-0 h-2/5"
                style="background: linear-gradient(180deg, transparent 0%, oklch(22% 0.045 150 / 0.85) 100%);"
                aria-hidden="true"
              ></div>
            </div>
            <figcaption class="absolute bottom-4 left-4 right-4 z-10 pointer-events-none">
              <div class="font-display text-lg md:text-xl text-[var(--color-paper)]">
                {a.title}
              </div>
              <div class="font-mono-tabular text-[11px] uppercase tracking-[0.14em] text-[var(--color-paper)]/75 mt-1">
                №{String(i + 1).padStart(2, "0")} &middot; {a.body}
              </div>
            </figcaption>
          </figure>
        </li>
      ))}
    </ul>

    <p class="mt-8 text-sm font-mono-tabular uppercase tracking-[0.14em] text-[var(--color-paper)]/55">
      Fiecare blat pornește de la un buștean ales cu grijă
    </p>
  </div>
</section>
