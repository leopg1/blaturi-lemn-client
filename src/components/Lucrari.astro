---
import { LUCRARI, PHONES } from "../config";

const primary = PHONES[0];
const featured = LUCRARI.filter((l) => l.featured);
const rest = LUCRARI.filter((l) => !l.featured);
---

<section id="lucrari" class="section-pad bg-[var(--color-paper-2)] border-t border-[var(--color-rule)] paper-grain">
  <div class="container-base">
    <div class="grid lg:grid-cols-12 gap-6 items-end mb-12 lg:mb-16">
      <div class="lg:col-span-7 reveal-heading">
        <div class="text-eyebrow mb-3">02 &mdash; Lucrări livrate</div>
        <h2 class="text-display-l">
          Blaturi pe care le-am lucrat<br />
          <span class="italic text-[var(--color-forest)]">din scândură până la tine în casă.</span>
        </h2>
      </div>
      <div class="lg:col-span-4 lg:col-start-9 reveal" style="transition-delay: 150ms;">
        <p class="text-[var(--color-ink-2)] leading-relaxed">
          Patru din ultimele lucrări. Mai multe poze și clienții care confirmă —
          <a href={`tel:${primary.tel}`} class="text-[var(--color-forest)] underline underline-offset-4 decoration-[var(--color-gold)] decoration-2">ți le trimit pe WhatsApp</a> când suni.
        </p>
      </div>
    </div>

    <!-- Featured: 2 lucrări mari -->
    <div class="grid md:grid-cols-2 gap-6 md:gap-8 mb-6 md:mb-8">
      {featured.map((l, i) => (
        <figure class="reveal-scale img-zoom group" style={`transition-delay: ${i * 120}ms`}>
          <div class="bg-[var(--color-paper)] border border-[var(--color-rule)] hover:border-[var(--color-forest)] transition-colors duration-300 overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden bg-[var(--color-paper-3)]">
              <img
                src={l.image}
                alt={l.alt}
                loading="lazy"
                decoding="async"
                class="block w-full h-full object-cover"
              />
            </div>
            <figcaption class="p-5 md:p-6 flex items-baseline justify-between gap-4 border-t border-[var(--color-rule)]">
              <div>
                <div class="font-display text-xl md:text-2xl text-[var(--color-ink)]">
                  {l.name}
                </div>
                <div class="font-mono-tabular text-xs uppercase tracking-[0.14em] text-[var(--color-ink-3)] mt-2">
                  <span>{l.loc}</span>
                  <span class="mx-2 text-[var(--color-rule)]">·</span>
                  <span>{l.sqm}</span>
                  <span class="mx-2 text-[var(--color-rule)]">·</span>
                  <span>{l.year}</span>
                </div>
              </div>
              <div class="font-mono-tabular text-xs text-[var(--color-gold-hi)] tracking-[0.14em]">
                №{String(l.id).padStart(2, "0")}
              </div>
            </figcaption>
          </div>
        </figure>
      ))}
    </div>

    <!-- Rest: 2-up grid (also large since we have only 2 more) -->
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {rest.map((l, i) => (
        <li class="reveal-scale img-zoom group" style={`transition-delay: ${i * 100}ms`}>
          <figure class="bg-[var(--color-paper)] border border-[var(--color-rule)] hover:border-[var(--color-forest)] transition-colors duration-300 overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden bg-[var(--color-paper-3)]">
              <img
                src={l.image}
                alt={l.alt}
                loading="lazy"
                decoding="async"
                class="block w-full h-full object-cover"
              />
            </div>
            <figcaption class="p-5 md:p-6 border-t border-[var(--color-rule)]">
              <div class="flex items-baseline justify-between mb-2">
                <div class="font-mono-tabular text-[10px] text-[var(--color-gold-hi)] tracking-[0.14em]">
                  №{String(l.id).padStart(2, "0")}
                </div>
                <div class="font-mono-tabular text-[10px] uppercase tracking-[0.14em] text-[var(--color-ink-3)]">
                  {l.year}
                </div>
              </div>
              <div class="font-display text-lg md:text-xl text-[var(--color-ink)] leading-tight">
                {l.name}
              </div>
              <div class="font-mono-tabular text-[11px] uppercase tracking-[0.14em] text-[var(--color-ink-3)] mt-1">
                {l.loc} &middot; {l.sqm}
              </div>
            </figcaption>
          </figure>
        </li>
      ))}
    </ul>
  </div>
</section>
